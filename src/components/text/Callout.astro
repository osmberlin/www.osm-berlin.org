---
import type { LayoutLanguage } from '@layouts/languages'
import { twJoin } from 'tailwind-merge'

type Props = {
  language: LayoutLanguage
}

const { language } = Astro.props
---

<div
  lang={language}
  class={twJoin(
    'lead',
    'first:prose-headings:mt-0 prose-p:first-of-type:!mt-0',
    'rounded-sm bg-yellow-100 p-3 leading-tight',
  )}
>
  <slot />
</div>
